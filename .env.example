# ============================================================
# RABBONI RESTAURANT — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# JWT Secret (generate a long random string)
JWT_SECRET=rabboni_super_secret_jwt_key_change_this_in_production_2026

# Admin credentials (change before going live)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=rabboni@admin2026
ADMIN_EMAIL=admin@rabbonirestaurant.com

# ── Paystack (https://dashboard.paystack.com) ──────────────
# Get your keys from your Paystack dashboard
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Hubtel SMS (https://developers.hubtel.com) ─────────────
# Register at hubtel.com and get your API credentials
HUBTEL_CLIENT_ID=xxxxxxxx
HUBTEL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HUBTEL_SENDER_ID=Rabboni
# Set to true to enable SMS sending
HUBTEL_ENABLED=false

# ── Email (Optional - for order/reservation notifications) ─
# Use Gmail App Password or SMTP service like Brevo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Rabboni Restaurant <noreply@rabbonirestaurant.com>
EMAIL_ENABLED=false

# ── Restaurant Info ────────────────────────────────────────
RESTAURANT_NAME=Rabboni Restaurant
RESTAURANT_PHONE=+233591447201
RESTAURANT_ADDRESS=Opposite Techiman Community Centre, First Floor OIB Building, Techiman

# Delivery fee in GHS
DELIVERY_FEE=10
FREE_DELIVERY_MINIMUM=100

# ── Frontend URL (for Paystack callback) ───────────────────
FRONTEND_URL=http://localhost:3000
